# cp .env.example .env.local

# Public site URL used for metadata (Open Graph, sitemap, robots.txt)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# OpenAI
OPENAI_API_KEY=

# Optional providers if you use them later
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
